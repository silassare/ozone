<html lang="{$global.lang}">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport"
			  content="width=device-width, height=device-height, initial-scale=1, maximum-scale=1, user-scalable=no, shrink-to-fit=no"/>

		<title>Redirect</title>

		<meta http-equiv="Refresh" content="5;url={oz_redirect_url}">
		<link href="https://fonts.googleapis.com/css?family=Ubuntu&display=swap" rel="stylesheet">

		<script type="text/javascript">
			window.location.href = "{oz_redirect_url}";
		</script>
		<style>
		{@import_raw 'oz://oz.css'}
		</style>
	</head>
	<body>
		<div id="oz-box">
			<span class="oz-logo"></span>
			<div class="oz-title">{$t('OZ_VIEW_REDIRECT_TITLE')}</div>
			<div class="oz-desc">
				<div class="oz-desc-item" style="text-align: center;">
				{$t('OZ_VIEW_REDIRECT_MESSAGE', $map('url', oz_redirect_url))}
				</div>
			</div>
		</div>
	</body>
</html>
