<html lang="{$global.lang}">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport"
			  content="width=device-width, height=device-height, initial-scale=1, maximum-scale=1, user-scalable=no, shrink-to-fit=no"/>

		<title>Error</title>

		<link href="https://fonts.googleapis.com/css?family=Ubuntu&display=swap" rel="stylesheet">
		<style>
		{@import_raw 'oz://oz.css'}
		</style>
	</head>
	<body>
		<div id="oz-box">
			<span class="oz-logo"></span>
			<div class="oz-title">{$oz_error_http_status} {$t(oz_error_title, oz_error_data)}</div>
			<div class="oz-desc">
				<div class="oz-desc-item">{$t(oz_error_message, oz_error_data)}</div>
				<div class="oz-desc-item">{oz_error_url}</div>
			</div>
			{@if $has($$, 'oz_error_back_url')}
			<a class="oz-btn" href="{oz_error_back_url}">{$t('OZ_VIEW_GO_BACK_BTN')}</a>
			{:else}
			<a class="oz-btn" href="{$global.base_url}">{$t('OZ_VIEW_GO_HOME_BTN')}</a>
			{/if}
		</div>
	</body>
</html>
